# ── Postgres (required) ────────────────────────────────────────────────────────
POSTGRES_USER=gcc_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=wardb

# ── Redis (required) ───────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis

# ── API authentication (required) ─────────────────────────────────────────────
# Clients must send this value in the X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change_me_api_key

# ── Discord ────────────────────────────────────────────────────────────────────
# Discord incoming webhook URL (required for alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Risk scoring ───────────────────────────────────────────────────────────────
RISK_WINDOW_MINUTES=60
ALERT_RISK_THRESHOLD=70
ALERT_DELTA_THRESHOLD=20
ALERT_KINETIC_HITS=3
ALERT_COOLDOWN_MINUTES=30

# ── Google News RSS queries ────────────────────────────────────────────────────
RSS_QUERIES=["Iran US strike missile", "Strait Hormuz tanker ship", "Iran nuclear IAEA ceasefire"]

# ── GDELT 2.1 Doc API queries ──────────────────────────────────────────────────
GDELT_QUERIES=["Iran US war strike missile Hormuz", "Iran nuclear ceasefire diplomacy"]
GDELT_MAX_RECORDS=100

# ── Scheduling (minutes) ───────────────────────────────────────────────────────
RSS_INGEST_INTERVAL_MINUTES=2
GDELT_INGEST_INTERVAL_MINUTES=5
RISK_COMPUTE_INTERVAL_MINUTES=5

# ── YouTube live stream config ─────────────────────────────────────────────────
YOUTUBE_STREAMS=[{"name":"Al Jazeera English","url":"https://www.youtube.com/@AlJazeeraEnglish/live"},{"name":"BBC News","url":"https://www.youtube.com/@BBCNews/live"},{"name":"CNN","url":"https://www.youtube.com/@CNN/live"},{"name":"Sky News","url":"https://www.youtube.com/@SkyNews/live"},{"name":"France 24","url":"https://www.youtube.com/@FRANCE24/live"}]

# ── Internal service URLs (set automatically via docker-compose env) ───────────
# API_BASE_URL=http://api:8000
# CELERY_BROKER_URL=redis://:change_me_redis@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:change_me_redis@redis:6379/1
# DATABASE_URL=postgresql+psycopg://gcc_user:change_me_postgres@db:5432/wardb
